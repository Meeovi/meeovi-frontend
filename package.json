{
  "name": "meeovi",
  "type": "commonjs",
  "main": "./nuxt.config",
  "files": [
    "components/",
    "layouts/",
    "middleware/",
    "pages/",
    "server/",
    "app.config.ts",
    "nuxt.config.ts",
    "tailwind.config.js"
  ],
  "version": "0.0.6",
  "description": "This is a storefront for Meeovi.",
  "author": "Sebastian Hilton (https://www.sebastianhilton.com)",
  "homepage": "https://www.meeovi.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Meeovi/meeovi-frontend"
  },
  "bugs": {
    "url": "https://github.com/Meeovi/meeovi-frontend/issues"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "m-commit": "git add . && git commit -m \"ready for update\"",
    "m-update": "git pull \"https://github.com/Meeovi/meeovi-frontend\"",
    "build:watch": "nuxt build --watch",
    "build": "nuxi build",
    "dev": "nuxi dev --port 3011",
    "ts-node": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}'",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "prep": "nuxi prepare",
    "analyze": "nuxi analyze",
    "check": "exit 0",
    "start": "concurrently \"npm start:gateway\"",
    "start:gateway": "cd graphql/ && npm start",
    "all": "npm-run-all --parallel dev start"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxt/image": "^1.3.0",
    "@nuxtjs/tailwindcss": "6.8.0",
    "@nuxtjs/turnstile": "^0.7.1",
    "@prisma/client": "^5.17.0",
    "@sidebase/nuxt-auth": "^0.8.1",
    "@storefront-ui/nuxt": "^2.5.1",
    "@tinymce/tinymce-vue": "latest",
    "@types/node": "^20.11.13",
    "cors": "^2.8.5",
    "lerna": "^8.1.7",
    "npm-run-all": "^4.1.5",
    "nuxt": "^3.12.4",
    "nuxt-disqus": "^1.0.1",
    "nuxt-echarts": "^0.1.0",
    "nuxt-layers-utils": "^0.3.0",
    "nuxt-schema-org": "3.0.1",
    "nuxt3-leaflet": "^1.0.12",
    "prisma": "^5.17.0",
    "sass": "^1.77.8",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@auth/express": "^0.6.0",
    "@auth/prisma-adapter": "^2.4.2",
    "@fortawesome/fontawesome-free": "^6.6.0",
    "@fortawesome/fontawesome-svg-core": "^6.2.1",
    "@fortawesome/free-solid-svg-icons": "^6.2.1",
    "@fortawesome/vue-fontawesome": "^3.0.2",
    "@graphql-yoga/plugin-apollo-inline-trace": "^3.6.3",
    "@mdi/font": "^7.4.47",
    "@nuxtjs/algolia": "^1.10.2",
    "@nuxtjs/apollo": "^5.0.0-alpha.14",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@searchkit/instantsearch-client": "^4.14.0",
    "@sentry/tracing": "^7.114.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@videojs/http-streaming": "^3.13.1",
    "@videojs/themes": "^1.0.1",
    "algoliasearch": "^4.24.0",
    "bcrypt": "^5.1.1",
    "concurrently": "^8.2.2",
    "cross-var": "^1.1.0",
    "dotenv": "latest",
    "dotenv-cli": "^7.3.0",
    "express": "^4.19.2",
    "graphql": "^16.9.0",
    "graphql-scalars": "^1.23.0",
    "instantsearch.js": "^4.73.2",
    "jquery": "^3.7.1",
    "next-auth": "^4.21.1",
    "nuxt-i18n": "latest",
    "reflect-metadata": "^0.2.2",
    "searchkit": "^4.13.0",
    "type-graphql": "^2.0.0-rc.2",
    "typegraphql-prisma": "^0.27.2",
    "video.js": "^8.16.1",
    "videojs-contrib-ads": "^7.1.0",
    "videojs-contrib-quality-levels": "latest",
    "videojs-share": "^3.2.1",
    "vite-plugin-vuetify": "^2.0.3",
    "vue-instantsearch": "^4.19.1",
    "vuetify": "^3.6.7"
  },
  "workspaces": [
    "layers/graphql",
    "layers/cms",
    "layers/commerce"
  ]
}
