{
  "name": "meeovi",
  "version": "0.0.6",
  "type": "module",
  "description": "This is a storefront for Meeovi.",
  "author": "Sebastian Hilton (https://www.sebastianhilton.com)",
  "homepage": "https://www.meeovi.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Meeovi/meeovi-frontend"
  },
  "bugs": {
    "url": "https://github.com/Meeovi/meeovi-frontend/issues"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "meeovi-commit": "git add . && git commit -m \"ready for update\"",
    "meeovi-update": "git pull \"https://github.com/Meeovi/meeovi-frontend\"",
    "start": "mesh start",
    "build": "nuxt build && mesh build",
    "dev": "nuxt dev --port 3011",
    "ts-node": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}'",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "analyze": "nuxi analyze",
    "gql-generate": "npx gqlg --schemaFilePath apollo/commerce/schema.graphql --destDirPath apollo/commerce/queries-mutations_subscriptions",
    "all": "npm-run-all --parallel dev start"
  },
  "devDependencies": {
    "@nuxt/content": "latest",
    "@nuxt/image": "^1.3.0",
    "@nuxt/types": "latest",
    "@nuxtjs/turnstile": "^0.7.1",
    "@tinymce/tinymce-vue": "latest",
    "@types/graphql": "^14.5.0",
    "@types/node": "^20.11.13",
    "cors": "latest",
    "npm-run-all": "^4.1.5",
    "nuxt": "^3.12.3",
    "nuxt3-leaflet": "^1.0.12",
    "sass": "^1.72.0",
    "ts-node": "latest",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@apollo/client": "^3.10.4",
    "@fortawesome/fontawesome-svg-core": "^6.2.1",
    "@fortawesome/free-solid-svg-icons": "^6.2.1",
    "@fortawesome/vue-fontawesome": "^3.0.2",
    "@logto/nuxt": "^0.3.1",
    "@mdi/font": "^7.4.47",
    "@nuxtjs/apollo": "^5.0.0-alpha.14",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@searchkit/instantsearch-client": "^4.13.0",
    "@stripe/stripe-js": "latest",
    "@types/graphql": "latest",
    "@types/node": "latest",
    "@vue/apollo-composable": "^4.0.2",
    "cross-var": "^1.1.0",
    "dotenv": "latest",
    "dotenv-cli": "^7.3.0",
    "fastify": "latest",
    "graphql": "^16.9.0",
    "jquery": "latest",
    "lodash-es": "latest",
    "nuxt-directus": "^5.6.1",
    "nuxt-gtag": "^1.1.2",
    "nuxt-i18n": "latest",
    "searchkit": "^4.12.0",
    "stripe": "^14.23.0",
    "video.js": "latest",
    "videojs-contrib-ads": "^7.1.0",
    "videojs-contrib-quality-levels": "latest",
    "videojs-share": "^3.2.1",
    "vite-plugin-vuetify": "^2.0.3",
    "vue-instantsearch": "^4.17.5",
    "vuetify": "^3.6.7"
  }
}
