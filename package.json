{
   "name": "meeovi",
   "version": "0.0.5",
   "description": "This is a template for the Meeovi.",
   "author": "Sebastian Hilton (https://www.sebastianhilton.com)",
   "homepage": "https://www.meeovi.com",
   "repository": {
      "type": "git",
      "url": "git+https://github.com/Meeovi/meeovi-frontend"
   },
   "bugs": {
      "url": "https://github.com/Meeovi/meeovi-frontend/issues"
   },
   "license": "MIT",
   "private": true,
   "scripts": {
      "start": "mesh start",
      "alternate-commit": "git add . && git commit -m \"ready for update\"",
      "alternate-update": "git pull \"https://github.com/Meeovi/meeovi-frontend\"",
      "prebuild": "mesh build",
      "build": "nuxt build",
      "dev": "nuxt dev --port 3011",
      "yoga": " node server/index.js",
      "ts-node": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}'",
      "generate": "nuxt generate",
      "codegen": "graphql-codegen --config ./packages/gateway/codegen.ts",
      "db-dev": "prisma migrate dev --schema=prisma/schema.prisma",
      "get-graphql-schema": "npx get-graphql-schema http://67.207.71.123:8011/graphql > apollo/schema.graphql",
      "gql-generate": "npx gqlg --schemaFilePath apollo/schema.graphql --destDirPath apollo/queries-mutations_subscriptions --depthLimit 1",
      "get-vendure-schema": "npx get-graphql-schema http://67.207.71.123:3000/shop-api > apollo/vendure/schema.graphql",
      "gql-vendure-generate": "npx gqlg --schemaFilePath apollo/vendure/schema.graphql --destDirPath apollo/vendure/queries-mutations_subscriptions --depthLimit 3",
      "preview": "nuxt preview",
      "analyze": "nuxi analyze",
      "all": "npm-run-all --parallel dev yoga"
   },
   "devDependencies": {
      "@nuxt/content": "latest",
      "@nuxt/types": "^2.15.8",
      "@nuxtjs/apollo": "next",
      "@nuxtjs/tailwindcss": "^6.10.3",
      "@sidebase/nuxt-auth": "latest",
      "@storefront-ui/vue": "^2.6.0",
      "@tinymce/tinymce-vue": "latest",
      "@types/graphql": "^14.5.0",
      "@types/node": "^20.11.13",
      "dayjs-nuxt": "^2.1.9",
      "graphql": "^15.8.0",
      "js-cookie": "^3.0.5",
      "npm-run-all": "^4.1.5",
      "nuxt": "latest",
      "nuxt-meilisearch": "latest",
      "prisma": "^5.9.0",
      "ts-node": "^10.9.2",
      "typescript": "^5.3.3"
   },
   "dependencies": {
      "@apollo/gateway": "^0.54.1",
      "@directus/sdk": "^11.0.2",
      "@envelop/apollo-federation": "^5.0.0",
      "@envelop/graphql-jit": "^8.0.1",
      "@envelop/parser-cache": "^7.0.0",
      "@envelop/sentry": "^8.0.0",
      "@envelop/validation-cache": "^7.0.0",
      "@fortawesome/fontawesome-svg-core": "^6.2.1",
      "@fortawesome/free-solid-svg-icons": "^6.2.1",
      "@fortawesome/vue-fontawesome": "^3.0.2",
      "@graphql-mesh/cli": "^0.88.5",
      "@graphql-mesh/graphql": "^0.96.3",
      "@graphql-mesh/mysql": "^0.96.4",
      "@graphql-mesh/openapi": "^0.97.5",
      "@graphql-yoga/plugin-apollo-inline-trace": "^3.1.1",
      "@graphql-yoga/plugin-sofa": "^3.1.1",
      "@types/js-cookie": "^3.0.6",
      "@vue-storefront/sdk": "^1.2.0",
      "@whatwg-node/fetch": "^0.9.16",
      "apollo-cache-inmemory": "^1.6.6",
      "apollo-client": "^2.6.10",
      "apollo-link-rest": "^0.9.0",
      "cors": "^2.8.5",
      "cross-var": "^1.1.0",
      "dotenv": "^16.3.1",
      "dotenv-cli": "^7.3.0",
      "fastify": "^4.26.0",
      "graphql-config": "^5.0.3",
      "graphql-tag": "^2.12.6",
      "graphql-yoga": "^5.1.1",
      "instantsearch.css": "^8.1.0",
      "jquery": "latest",
      "nuxt-directus": "^5.6.0",
      "nuxt-gtag": "^1.1.2",
      "nuxt-security": "^0.10.1",
      "reflect-metadata": "^0.2.1",
      "requrl": "^3.0.2",
      "sitemap": "^7.1.1",
      "type-graphql": "^1.1.1",
      "video.js": "latest",
      "videojs-contrib-ads": "^7.1.0",
      "videojs-contrib-quality-levels": "latest",
      "videojs-share": "^3.2.1",
      "vue-instantsearch": "^4.13.2",
      "vuetify": "latest"
   }
}
