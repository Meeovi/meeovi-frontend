generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex", "metrics"]
}

generator typegraphql {
  provider           = "typegraphql-prisma"
  output             = "../prisma/generated/type-graphql"
  emitTranspiledCode = "false"
}

datasource db {
  provider = "mysql"
  url      = env("MY_SQL")
}

model acl_role {
  id               Bytes              @id @db.Binary(16)
  name             String             @db.VarChar(255)
  description      String?            @db.LongText
  privileges       String             @db.LongText
  created_at       DateTime
  updated_at       DateTime?
  deleted_at       DateTime?
  acl_user_role    acl_user_role[]
  app              app[]
  integration_role integration_role[]
}

model acl_user_role {
  user_id     Bytes     @db.Binary(16)
  acl_role_id Bytes     @db.Binary(16)
  created_at  DateTime
  updated_at  DateTime?
  acl_role    acl_role  @relation(fields: [acl_role_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk.acl_user_role.acl_role_id")
  user        user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk.acl_user_role.user_id")

  @@id([user_id, acl_role_id])
  @@index([acl_role_id], map: "fk.acl_user_role.acl_role_id")
}

model admin_elasticsearch_index_task {
  id        Bytes  @id @db.Binary(16)
  index     String @db.VarChar(500)
  alias     String @db.VarChar(500)
  entity    String @db.VarChar(500)
  doc_count Int
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model adyen_notification {
  id                        Bytes     @id @db.Binary(16)
  pspreference              String?   @db.VarChar(255)
  original_reference        String?   @db.VarChar(255)
  merchant_reference        String?   @db.VarChar(255)
  event_code                String?   @db.VarChar(255)
  success                   Boolean?
  payment_method            String?   @db.VarChar(255)
  amount_value              String?   @db.VarChar(255)
  amount_currency           String?   @db.VarChar(255)
  reason                    String?   @db.VarChar(255)
  live                      Boolean?
  additional_data           String?   @db.Text
  done                      Boolean   @default(false)
  processing                Boolean?  @default(false)
  scheduled_processing_time DateTime?
  error_count               Int?
  error_message             String?   @db.Text
  created_at                DateTime
  updated_at                DateTime?

  @@index([event_code], map: "ADYEN_NOTIFICATION_EVENT_CODE")
  @@index([merchant_reference, event_code], map: "ADYEN_NOTIFICATION_MERCHANT_REFERENCE_EVENT_CODE")
  @@index([pspreference], map: "ADYEN_NOTIFICATION_PSPREFERENCE")
  @@index([pspreference, event_code], map: "ADYEN_NOTIFICATION_PSPREFERENCE_EVENT_CODE")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model adyen_payment {
  id                       Bytes             @id @db.Binary(16)
  pspreference             String?           @unique(map: "UQ_ADYEN_PAYMENT_PSPREFERENCE") @db.VarChar(255)
  original_reference       String?           @db.VarChar(255)
  merchant_reference       String?           @db.VarChar(255)
  merchant_order_reference String?           @db.VarChar(255)
  order_transaction_id     Bytes             @db.Binary(16)
  payment_method           String            @db.VarChar(255)
  amount_value             Int
  amount_currency          String            @db.VarChar(255)
  additional_data          String?           @db.Text
  capture_mode             String?           @db.VarChar(255)
  created_at               DateTime
  updated_at               DateTime?
  order_transaction        order_transaction @relation(fields: [order_transaction_id], references: [id], onUpdate: Restrict, map: "fk.adyen_payment.order_transaction_id")

  @@index([merchant_order_reference], map: "ADYEN_PAYMENT_MERCHANT_ORDER_REFERENCE")
  @@index([merchant_reference], map: "ADYEN_PAYMENT_MERCHANT_REFERENCE")
  @@index([order_transaction_id], map: "fk.adyen_payment.order_transaction_id")
}

model adyen_payment_capture {
  id                   Bytes             @id @db.Binary(16)
  order_transaction_id Bytes             @db.Binary(16)
  psp_reference        String?           @db.VarChar(255)
  source               String            @db.VarChar(255)
  status               String            @db.VarChar(255)
  created_at           DateTime
  updated_at           DateTime?
  amount               Int
  order_transaction    order_transaction @relation(fields: [order_transaction_id], references: [id], onUpdate: Restrict, map: "fk.adyen_payment_capture.order_transaction_id")

  @@index([order_transaction_id], map: "fk.adyen_payment_capture.order_transaction_id")
}

model adyen_payment_response {
  id                   Bytes     @id @db.Binary(16)
  order_transaction_id Bytes?    @db.Binary(16)
  result_code          String    @db.VarChar(255)
  response             String?   @db.Text
  created_at           DateTime
  updated_at           DateTime?
}

model adyen_payment_state_data {
  id         Bytes     @id @db.Binary(16)
  token      String?   @db.VarChar(255)
  state_data String?   @db.Text
  created_at DateTime
  updated_at DateTime?
}

model adyen_refund {
  id                   Bytes             @id @db.Binary(16)
  order_transaction_id Bytes             @db.Binary(16)
  psp_reference        String?           @db.VarChar(255)
  source               String            @db.VarChar(255)
  status               String            @db.VarChar(255)
  created_at           DateTime
  updated_at           DateTime?
  amount               Int
  order_transaction    order_transaction @relation(fields: [order_transaction_id], references: [id], onUpdate: Restrict, map: "fk.adyen_refund.order_transaction_id")

  @@index([order_transaction_id], map: "fk.adyen_refund.order_transaction_id")
}

model app {
  id                         Bytes                        @id @db.Binary(16)
  name                       String                       @unique(map: "uniq.name") @db.VarChar(255)
  path                       String                       @db.VarChar(255)
  author                     String?                      @db.VarChar(255)
  copyright                  String?                      @db.VarChar(255)
  license                    String?                      @db.VarChar(255)
  privacy                    String?                      @db.VarChar(255)
  version                    String                       @db.VarChar(255)
  base_app_url               String?                      @db.VarChar(1024)
  active                     Boolean                      @default(false)
  allow_disable              Boolean                      @default(true)
  configurable               Boolean                      @default(false)
  icon                       Bytes?                       @db.MediumBlob
  app_secret                 String?                      @db.VarChar(255)
  modules                    String?                      @db.LongText
  main_module                String?                      @db.LongText
  cookies                    String?                      @db.LongText
  allowed_hosts              String?                      @db.LongText
  integration_id             Bytes                        @db.Binary(16)
  acl_role_id                Bytes                        @db.Binary(16)
  created_at                 DateTime
  updated_at                 DateTime?
  template_load_priority     Int?                         @default(0)
  acl_role                   acl_role                     @relation(fields: [acl_role_id], references: [id], map: "fk.app.acl_role_id")
  integration                integration                  @relation(fields: [integration_id], references: [id], map: "fk.app.integration_id")
  app_action_button          app_action_button[]
  app_administration_snippet app_administration_snippet[]
  app_cms_block              app_cms_block[]
  app_flow_action            app_flow_action[]
  app_flow_event             app_flow_event[]
  app_payment_method         app_payment_method[]
  app_script_condition       app_script_condition[]
  app_shipping_method        app_shipping_method[]
  app_template               app_template[]
  app_translation            app_translation[]
  custom_entity              custom_entity[]
  custom_field_set           custom_field_set[]
  script                     script[]
  tax_provider               tax_provider[]
  webhook                    webhook[]

  @@index([acl_role_id], map: "fk.app.acl_role_id")
  @@index([integration_id], map: "fk.app.integration_id")
}

model app_action_button {
  id                            Bytes                           @id @db.Binary(16)
  entity                        String                          @db.VarChar(255)
  view                          String                          @db.VarChar(255)
  url                           String                          @db.VarChar(255)
  action                        String                          @db.VarChar(255)
  open_new_tab                  Boolean                         @default(false)
  app_id                        Bytes                           @db.Binary(16)
  created_at                    DateTime
  updated_at                    DateTime?
  app                           app                             @relation(fields: [app_id], references: [id], onDelete: Cascade, map: "fk.app_action_button.app_id")
  app_action_button_translation app_action_button_translation[]

  @@unique([action, app_id], map: "uniq.app_action_button.action")
  @@index([app_id], map: "fk.app_action_button.app_id")
}

model app_action_button_translation {
  label                String?           @db.VarChar(255)
  created_at           DateTime
  updated_at           DateTime?
  app_action_button_id Bytes             @db.Binary(16)
  language_id          Bytes             @db.Binary(16)
  app_action_button    app_action_button @relation(fields: [app_action_button_id], references: [id], onDelete: Cascade, map: "fk.app_action_button_translation.app_action_button_id")
  language             language          @relation(fields: [language_id], references: [id], onDelete: Cascade, map: "fk.app_action_button_translation.language_id")

  @@id([app_action_button_id, language_id])
  @@index([app_action_button_id], map: "fk.app_action_button_translation.app_action_button_id")
  @@index([language_id], map: "fk.app_action_button_translation.language_id")
}

model app_administration_snippet {
  id         Bytes     @id @db.Binary(16)
