model cart {
  token              String          @id @db.VarChar(50)
  name               String?         @db.VarChar(500)
  cart               String          @db.LongText
  price              Float           @db.Float
  line_item_count    String          @db.VarChar(42)
  currency_id        Bytes           @db.Binary(16)
  shipping_method_id Bytes           @db.Binary(16)
  payment_method_id  Bytes           @db.Binary(16)
  country_id         Bytes           @db.Binary(16)
  customer_id        Bytes?          @db.Binary(16)
  sales_channel_id   Bytes           @db.Binary(16)
  rule_ids           String          @db.LongText
  created_at         DateTime
  updated_at         DateTime?
  auto_increment     BigInt          @unique(map: "auto_increment") @default(autoincrement())
  country            country         @relation(fields: [country_id], references: [id], onDelete: Cascade, map: "fk.cart.country_id")
  currency           currency        @relation(fields: [currency_id], references: [id], onDelete: Cascade, map: "fk.cart.currency_id")
  customer           customer?       @relation(fields: [customer_id], references: [id], onDelete: Cascade, map: "fk.cart.customer_id")
  payment_method     payment_method  @relation(fields: [payment_method_id], references: [id], onDelete: Cascade, map: "fk.cart.payment_method_id")
  sales_channel      sales_channel   @relation(fields: [sales_channel_id], references: [id], onDelete: Cascade, map: "fk.cart.sales_channel_id")
  shipping_method    shipping_method @relation(fields: [shipping_method_id], references: [id], onDelete: Cascade, map: "fk.cart.shipping_method_id")

  @@index([country_id], map: "fk.cart.country_id")
  @@index([currency_id], map: "fk.cart.currency_id")
  @@index([customer_id], map: "fk.cart.customer_id")
  @@index([payment_method_id], map: "fk.cart.payment_method_id")
  @@index([sales_channel_id], map: "fk.cart.sales_channel_id")
  @@index([shipping_method_id], map: "fk.cart.shipping_method_id")
  @@index([created_at], map: "idx.cart.created_at")
}

