  customer_customer_updated_by_idTouser customer[]              @relation("customer_updated_by_idTouser")
  import_export_log                     import_export_log[]
  media_media_user_idTouser             media[]                 @relation("media_user_idTouser")
  notification                          notification[]
  order_order_created_by_idTouser       order[]                 @relation("order_created_by_idTouser")
  order_order_updated_by_idTouser       order[]                 @relation("order_updated_by_idTouser")
  state_machine_history                 state_machine_history[]
  media_user_avatar_idTomedia           media?                  @relation("user_avatar_idTomedia", fields: [avatar_id], references: [id], onUpdate: Restrict, map: "fk.user.avatar_id")
  locale                                locale                  @relation(fields: [locale_id], references: [id], map: "fk.user.locale_id")
  user_access_key                       user_access_key[]
  user_config                           user_config[]
  user_recovery                         user_recovery?

  @@index([avatar_id], map: "fk.user.avatar_id")
  @@index([locale_id], map: "fk.user.locale_id")
}

model user_access_key {
  id                Bytes     @id @db.Binary(16)
  user_id           Bytes     @db.Binary(16)
  write_access      Boolean?  @default(false)
  access_key        String    @db.VarChar(255)
  secret_access_key String    @db.VarChar(255)
  last_usage_at     DateTime?
  custom_fields     String?   @db.LongText
  created_at        DateTime
  updated_at        DateTime?
  user              user      @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk.user_access_key.user_id")

  @@index([access_key], map: "idx.user_access_key.access_key")
  @@index([user_id], map: "idx.user_access_key.user_id_")
}

model user_config {
  id         Bytes     @id @db.Binary(16)
  user_id    Bytes     @db.Binary(16)
  key        String    @db.VarChar(255)
  value      String?   @db.LongText
  created_at DateTime
  updated_at DateTime?
  user       user      @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk.user_config.user_id")

  @@unique([user_id, key], map: "uniq.user_id_key")
}

model user_recovery {
  id         Bytes     @id @db.Binary(16)
  user_id    Bytes     @unique(map: "uniq.user_recovery.user_id") @db.Binary(16)
  hash       String    @db.VarChar(255)
  created_at DateTime
  updated_at DateTime?
  user       user      @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk.user_recovery.user_id")
}

model version {
  id         Bytes     @id @db.Binary(16)
  name       String    @db.VarChar(255)
  created_at DateTime
  updated_at DateTime?

  @@index([created_at], map: "idx.version.created_at")
}

model version_commit {
  id                  Bytes                 @id @db.Binary(16)
  auto_increment      BigInt                @unique(map: "auto_increment") @default(autoincrement())
  is_merge            Boolean               @default(false)
  message             String?               @db.VarChar(5000)
  user_id             Bytes?                @db.Binary(16)
  integration_id      Bytes?                @db.Binary(16)
  version_id          Bytes                 @db.Binary(16)
  created_at          DateTime
  updated_at          DateTime?
  version_commit_data version_commit_data[]

  @@index([created_at], map: "idx.version_commit.created_at")
}

model version_commit_data {
  id                Bytes          @id @db.Binary(16)
  auto_increment    BigInt         @unique(map: "auto_increment") @default(autoincrement())
  version_commit_id Bytes          @db.Binary(16)
  entity_name       String         @db.VarChar(100)
  entity_id         String         @db.LongText
  action            String         @db.VarChar(100)
  payload           String         @db.LongText
  user_id           Bytes?         @db.Binary(16)
  integration_id    Bytes?         @db.Binary(16)
  created_at        DateTime
  updated_at        DateTime?
  version_commit    version_commit @relation(fields: [version_commit_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk.version_commit_data.version_commit_id")

  @@index([version_commit_id], map: "fk.version_commit_data.version_commit_id")
}

model versions {
  version BigInt   @id
  name    String?  @db.Text
  md5     String?  @db.Text
  run_at  DateTime @default(now()) @db.Timestamp(0)
}

model webhook {
  id                Bytes     @id @db.Binary(16)
  name              String    @db.VarChar(255)
  event_name        String    @db.VarChar(500)
  url               String    @db.VarChar(500)
  app_id            Bytes?    @db.Binary(16)
  active            Boolean?  @default(true)
  created_at        DateTime
  updated_at        DateTime?
  error_count       Int       @default(0)
  only_live_version Boolean   @default(false)
  app               app?      @relation(fields: [app_id], references: [id], onDelete: Cascade, map: "fk.webhook.app_id")

  @@unique([name, app_id], map: "uniq.webhook.name")
  @@index([app_id], map: "fk.webhook.app_id")
}

model webhook_event_log {
  id                         Bytes     @id @db.Binary(16)
  app_name                   String?   @db.VarChar(255)
  webhook_name               String    @db.Text
  event_name                 String    @db.VarChar(255)
  delivery_status            String    @db.VarChar(255)
  timestamp                  Int?
  processing_time            Int?
  app_version                String?   @db.VarChar(255)
  request_content            String?   @db.LongText
  response_content           String?   @db.LongText
  response_status_code       Int?
  response_reason_phrase     String?   @db.VarChar(255)
  url                        String    @db.VarChar(500)
  serialized_webhook_message Bytes?
  custom_fields              String?   @db.LongText
  created_at                 DateTime
  updated_at                 DateTime?
  only_live_version          Boolean   @default(false)
}
